# Copy to .env before running: cp .env.example .env  (Windows: copy .env.example .env)

# Postgres connection string. Locally you can use a free Neon/Supabase database,
# or a local Postgres. On Vercel, the Neon/Postgres integration sets this for you.
# Use a DIRECT (non-pooled) connection string so schema creation works.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# 32+ byte secret used to sign session cookies. Replace in production.
AUTH_SECRET="sunaidi-design-central-dev-secret-please-change-me-000"

# Demo 2FA bypass — accepts code 123456. Set to 0 for real production.
AUTH_DEMO_BYPASS="1"

# ── First-run data ───────────────────────────────────────────────────────
# On an EMPTY database the app initializes itself once. Choose one:
#
#  • Demo dataset (6 sample users, events, posts). For trying it out:
# SEED_DEMO="1"
#
#  • Production bootstrap (default when SEED_DEMO is unset): creates ONE real
#    Admin from the values below plus one empty starter event. Nothing else.
#    Both are required (password >= 8 chars) or init is skipped until they're set.
# ADMIN_EMAIL="you@yourcompany.com"
# ADMIN_PASSWORD="a-strong-password"
# ADMIN_NAME="Your Name"
# STARTER_EVENT_NAME="My first event"

# ── Media storage ────────────────────────────────────────────────────────
# Optional. If these S3 credentials are set, uploaded post media goes straight
# to an S3-compatible bucket (Supabase Storage or AWS S3) via a presigned URL,
# so large videos aren't limited by the serverless request-body cap. If they
# are left unset, media falls back to bytes stored in Postgres (max ~4 MB).
#
# Supabase: Dashboard → Storage → create a bucket, then Settings → S3 access
# keys → "New access key". The endpoint is shown there, e.g.
#   https://<project-ref>.storage.supabase.co/storage/v1/s3
# S3_ENDPOINT=""            # leave empty for real AWS S3
# S3_REGION="us-east-1"     # your Supabase project region
# S3_BUCKET="media"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# MEDIA_MAX_MB="100"        # overall upload cap (default 100 with S3/Cloudinary, 4 in db mode)
# MEDIA_VIDEO_MAX_MB="100"  # max video upload size (Cloudinary free allows ~100 MB)
# MEDIA_IMAGE_MAX_MB="10"   # max image upload size
# MEDIA_VIDEO_TRANSFORM_MAX_MB="40"  # videos above this publish uncropped (Cloudinary
#                                    # can't transform larger videos on the free plan)

# Cloudinary (optional, takes precedence over S3/db when set): uploads go to
# Cloudinary, which also auto-crops one master into each platform's aspect
# ratio (9:16 / 4:5 / 16:9). Get these from the Cloudinary console. Either set
# the single URL, or the three separate vars.
# CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
#   — or —
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ── Instagram publishing ─────────────────────────────────────────────────
# Base host for the Instagram Content Publishing API. Default matches the
# "Instagram API with Facebook Login" setup (graph.facebook.com). Set to
# https://graph.instagram.com/v21.0 only if you used "Instagram API with
# Instagram Login" instead. (The per-account token + IG user ID are entered in
# the app's Integrations screen, not here.)
# IG_API_BASE="https://graph.facebook.com/v21.0"

# ── X (Twitter) publishing ────────────────────────────────────────────────
# App-level OAuth 1.0a consumer credentials from the X Developer Portal
# (Keys and tokens → "API Key and Secret"). The per-account Access Token +
# Access Token Secret are entered in the app's Integrations screen (field 1 =
# access token, field 2 = access token secret). The app must have "Read and
# write" permission and the access token must be generated AFTER setting that.
# X_API_KEY=""
# X_API_SECRET=""

# ── LinkedIn publishing ───────────────────────────────────────────────────
# OAuth 2.0 app credentials from the LinkedIn Developer Portal (Auth tab).
# Connecting is a one-click OAuth flow in the Integrations screen — no manual
# token entry. Requires the app products "Share on LinkedIn" (w_member_social)
# and "Sign In with LinkedIn using OpenID Connect" (openid, profile).
# The Authorized redirect URL in the LinkedIn app MUST be exactly:
#   https://<your-domain>/api/linkedin/callback
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""
# Optional — pin the redirect URI if the request origin isn't your public URL:
# LINKEDIN_REDIRECT_URI="https://<your-domain>/api/linkedin/callback"
# Optional — override the monthly REST API version (LinkedIn-Version header):
# LINKEDIN_VERSION="202506"
# Set to 1 to also request Company-Page posting scopes (needs the Community
# Management API product added to the LinkedIn app). Leave unset for member-only
# posting — requesting org scopes without the product breaks the whole sign-in.
# LINKEDIN_ORG_POSTING="1"

# ── Analytics warming (optional) ──────────────────────────────────────────
# Analytics data is cached per account in the DB and refreshed on read when
# older than ~20 min. To keep it ALWAYS warm (never a slow load), schedule a
# call to GET /api/cron/refresh-analytics every ~15 min with the header
# Authorization: Bearer <CRON_SECRET>. Set CRON_SECRET to enable that endpoint
# (Vercel Cron sends this header automatically; or use any external scheduler).
# CRON_SECRET=""

# ── Auto-publish ──────────────────────────────────────────────────────────
# Approved posts publish themselves when their scheduled time arrives, driven by
# GET /api/cron/publish-due (same CRON_SECRET as above; the GitHub Actions
# workflow .github/workflows/auto-publish.yml calls it every ~5 min). Scheduled
# times are wall-clock in this timezone offset (KSA by default).
# PUBLISH_TZ="+03:00"
