// Sunaidi Design Central — data model
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id        String          @id @default(cuid())
  slug      String          @unique
  nameEn    String
  nameAr    String
  color     String
  barIx     Int             @default(0)
  order     Int             @default(0)
  accounts  SocialAccount[]
  posts     Post[]
  approvals Approval[]
  createdAt DateTime        @default(now())
}

model SocialAccount {
  id        String  @id @default(cuid())
  eventId   String
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  platform   String // instagram | tiktok | x | facebook | linkedin
  handle     String
  followers  Int     @default(0)
  connected  Boolean @default(false)
  apiKey     String? // access token used to publish
  externalId String? // platform account id (IG Business Account ID / Page ID / URN)

  @@unique([eventId, platform])
}

model Post {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date         String // YYYY-MM-DD
  time         String // HH:mm
  titleEn      String
  titleAr      String
  captionEn    String
  captionAr    String
  platformsCsv String // comma-separated platform keys
  status       String   @default("scheduled") // scheduled | posted
  approval     String   @default("pending") // pending | approved | declined
  format       String? // Image | Video | Reel (content type of the attached media)
  mediaId      String?
  media        Media?   @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

// Uploaded post media. Two storage drivers (lib/media.ts):
//   - "db": bytes stored in `data` (no external service; capped by the Vercel
//     function body limit ~4 MB).
//   - "s3": bytes live in an S3-compatible bucket (Supabase Storage / AWS S3);
//     `storageKey` is the object key, uploaded client-direct so large files
//     bypass the function body limit. `data` is null.
model Media {
  id         String   @id @default(cuid())
  eventId    String?
  filename   String
  mimeType   String
  size       Int
  kind       String // Image | Video | Reel
  driver     String   @default("db") // db | s3 | cloudinary
  storageKey String? // object key (s3) / public_id (cloudinary)
  status     String   @default("ready") // pending | ready
  width      Int? // source pixel dimensions (used to skip no-op crops)
  height     Int?
  data       Bytes? // bytes when driver = db
  posts      Post[]
  createdAt  DateTime @default(now())
}

model Approval {
  id            String  @id @default(cuid())
  eventId       String
  event         Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  whoEn         String
  whoAr         String
  init          String
  avColor       String
  titleEn       String
  titleAr       String
  captionEn     String
  captionAr     String
  platformsCsv  String
  whenLabel     String // today | yesterday
  status        String  @default("pending") // pending | approved | declined
  editedCaption String?
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  init         String
  avColor      String
  role         String // Admin | Manager | Editor | Viewer
  status       String   @default("active") // active | invited
  mfaEnabled   Boolean  @default(false)
  totpSecret   String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model Setting {
  id               Int     @id @default(1)
  requireMfa       Boolean @default(false)
  autoPublish      Boolean @default(true)
  weekStartsMonday Boolean @default(false)
  tone             String  @default("punchy")
  lang             String  @default("en")
}

// Cached Instagram analytics per account (raw IgAccountData JSON), so the
// Analytics screen reads a ready snapshot instead of calling the Graph API on
// every request. Refreshed on read when stale and by the cron endpoint.
model InsightSnapshot {
  externalId String   @id // IG business account id
  data       Json
  fetchedAt  DateTime @default(now())
}

// Security audit trail + captured server errors. Written best-effort so a
// logging failure never breaks the action being logged.
model AuditLog {
  id         String   @id @default(cuid())
  at         DateTime @default(now())
  actorId    String? // user id that performed the action (null for anonymous)
  actorEmail String?
  actorRole  String?
  action     String // e.g. auth.login, user.create, account.connect, post.publish, error
  target     String? // subject of the action (email, event/post, endpoint)
  detail     String? // extra context or error message
  level      String   @default("info") // info | warning | error
  ip         String?

  @@index([at])
}
